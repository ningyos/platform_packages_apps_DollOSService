android_app {
    name: "DollOSService",
    srcs: [
        "src/**/*.kt",
        "aidl/**/*.aidl",
    ],
    aidl: {
        local_include_dirs: ["aidl"],
    },
    platform_apis: true,
    privileged: true,
    certificate: "platform",
    static_libs: [
        "androidx.core_core-ktx",
    ],
    kotlincflags: ["-Xjvm-default=all"],
}
